diff --git a/CMakeLists.txt b/CMakeLists.txt
index abd0874..ca54cd5 100644
--- a/CMakeLists.txt
+++ src/moveit/geometric_shapes/CMakeLists.txt
@@ -39,6 +39,42 @@ find_package(Eigen3 REQUIRED)
 
 find_package(ament_cmake REQUIRED)
 find_package(assimp REQUIRED)
+if(NOT TARGET assimp::assimp)
+  if(TARGET assimp)
+    add_library(assimp::assimp ALIAS assimp)
+  else()
+    set(_assimp_link_libs "")
+    if(assimp_ABS_LIBRARIES)
+      list(APPEND _assimp_link_libs ${assimp_ABS_LIBRARIES})
+    endif()
+    if(assimp_LIBRARIES)
+      list(APPEND _assimp_link_libs ${assimp_LIBRARIES})
+    endif()
+    if(ASSIMP_LIBRARIES)
+      list(APPEND _assimp_link_libs ${ASSIMP_LIBRARIES})
+    endif()
+    set(_assimp_resolved_link_libs "")
+    foreach(_assimp_lib IN LISTS _assimp_link_libs)
+      if(_assimp_lib STREQUAL "assimp" AND assimp_ABS_LIBRARIES)
+        list(APPEND _assimp_resolved_link_libs "${assimp_ABS_LIBRARIES}")
+      else()
+        list(APPEND _assimp_resolved_link_libs "${_assimp_lib}")
+      endif()
+    endforeach()
+    list(REMOVE_DUPLICATES _assimp_resolved_link_libs)
+    set(_assimp_link_libs "${_assimp_resolved_link_libs}")
+    if(NOT _assimp_link_libs)
+      message(FATAL_ERROR "assimp::assimp target not found and assimp_LIBRARIES is empty.")
+    endif()
+    add_library(assimp::assimp INTERFACE IMPORTED)
+    set_target_properties(assimp::assimp PROPERTIES INTERFACE_LINK_LIBRARIES "${_assimp_link_libs}")
+    if(assimp_INCLUDE_DIRS)
+      set_property(TARGET assimp::assimp PROPERTY INTERFACE_INCLUDE_DIRECTORIES "${assimp_INCLUDE_DIRS}")
+    elseif(ASSIMP_INCLUDE_DIRS)
+      set_property(TARGET assimp::assimp PROPERTY INTERFACE_INCLUDE_DIRECTORIES "${ASSIMP_INCLUDE_DIRS}")
+    endif()
+  endif()
+endif()
 find_package(console_bridge REQUIRED)
 find_package(console_bridge_vendor REQUIRED)
 find_package(eigen_stl_containers REQUIRED)
