diff --git a/CMakeLists.txt b/CMakeLists.txt
--- a/CMakeLists.txt
+++ src/ros2/rviz/rviz_ogre_vendor/CMakeLists.txt
@@ -129,7 +129,19 @@
       list(APPEND extra_cmake_args "-DCMAKE_OSX_ARCHITECTURES='arm64'")
     else()
       list(APPEND extra_cmake_args "-DCMAKE_OSX_ARCHITECTURES='x86_64'")
+    endif()
+    if(DEFINED CMAKE_OSX_SYSROOT AND NOT CMAKE_OSX_SYSROOT STREQUAL "")
+      list(APPEND extra_cmake_args "-DCMAKE_OSX_SYSROOT=${CMAKE_OSX_SYSROOT}")
+    elseif(DEFINED ENV{SDKROOT} AND NOT "$ENV{SDKROOT}" STREQUAL "")
+      list(APPEND extra_cmake_args "-DCMAKE_OSX_SYSROOT=$ENV{SDKROOT}")
+    endif()
+    if(DEFINED CMAKE_OSX_DEPLOYMENT_TARGET AND NOT CMAKE_OSX_DEPLOYMENT_TARGET STREQUAL "")
+      list(APPEND extra_cmake_args "-DCMAKE_OSX_DEPLOYMENT_TARGET=${CMAKE_OSX_DEPLOYMENT_TARGET}")
     endif()
+    if(DEFINED ENV{SDKROOT} AND NOT "$ENV{SDKROOT}" STREQUAL "")
+      set(OGRE_C_FLAGS "${OGRE_C_FLAGS} -isysroot $ENV{SDKROOT}")
+      set(OGRE_CXX_FLAGS "${OGRE_CXX_FLAGS} -isysroot $ENV{SDKROOT}")
+    endif()
   else()  # Linux
     set(OGRE_C_FLAGS "${OGRE_C_FLAGS} -w")
     # include Clang -Wno-everything to disable warnings in that build. GCC doesn't mind it
